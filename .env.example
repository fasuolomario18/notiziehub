# ─────────────────────────────────────────────────────────────
# notiziehub — variabili d'ambiente (copia in .env.local)
# Il sito GIRA anche senza nulla di questo (usa i dati seed).
# Aggiungi le chiavi per passare ai dati reali / live.
# ─────────────────────────────────────────────────────────────

# URL pubblico del sito (per canonical, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://notizihub.com

# Verifica Google Search Console (metodo "tag HTML"): incolla solo il content
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# --- Database (Neon o Supabase Postgres) ---
# Senza questa, il sito usa i dati seed.
DATABASE_URL=

# --- Fonti dati ufficiali ---
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- Analytics ---
NEXT_PUBLIC_GA_ID=
# opzionale, privacy-friendly:
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# --- Pubblicità (come Globary/Prezzioggi: Adsterra + HilltopAds) ---
NEXT_PUBLIC_ADSTERRA_KEY=
NEXT_PUBLIC_HILLTOP_SRC=
# AdSense opzionale, solo se/quando approvato:
NEXT_PUBLIC_ADSENSE_CLIENT=

# --- Email richieste di rimozione (opzionale, via Resend) ---
RESEND_API_KEY=
RESEND_FROM=notiziehub <onboarding@resend.dev>
